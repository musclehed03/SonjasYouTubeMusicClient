{
  "entities": {
    "UserSettings": {
      "title": "User Settings",
      "description": "Stores persistent user preferences and audio settings.",
      "type": "object",
      "properties": {
        "theme": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" },
            "tertiaryColor": { "type": "string" },
            "accentColor": { "type": "string" },
            "textColor": { "type": "string" },
            "fontFamily": { "type": "string" },
            "fontSize": { "type": "number" },
            "visualizerOpacity": { "type": "number" },
            "visualizerType": { "type": "string" },
            "visualizerColor": { "type": "string" },
            "dynamicTheme": { "type": "boolean" },
            "lyricsOpacity": { "type": "number" },
            "lyricsFontSize": { "type": "number" },
            "lyricsFontFamily": { "type": "string" },
            "lyricsColor": { "type": "string" },
            "lyricsAlignment": { "type": "string" },
            "visualizerNowPlaying": { "type": "boolean" },
            "visualizerNowPlayingOpacity": { "type": "number" }
          }
        },
        "audio": {
          "type": "object",
          "properties": {
            "eqPreset": { "type": "string" },
            "customEq": { "type": "array", "items": { "type": "number" } },
            "spatialAudio": { "type": "boolean" },
            "dolbyAtmos": { "type": "boolean" },
            "gaplessPlayback": { "type": "boolean" },
            "blockExplicit": { "type": "boolean" },
            "seekTime": { "type": "number" }
          }
        },
        "appSettings": {
          "type": "object",
          "properties": {
            "losslessAudio": { "type": "boolean" },
            "crossfadeDuration": { "type": "number" },
            "volumeNormalization": { "type": "boolean" },
            "artistBlocking": { "type": "boolean" },
            "autoplay": { "type": "boolean" },
            "seekTime": { "type": "number" }
          }
        },
        "blockedSongs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "likedSongs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}/settings/preferences": {
      "schema": "UserSettings",
      "description": "User-specific settings and preferences."
    }
  }
}
